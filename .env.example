# GSL Marketing Mirror — environment variables
# Copy this file to .env.local for local dev (node server.js), and add the same keys in
# Vercel → Project → Settings → Environment Variables for production. NEVER commit real values
# (.env / .env.local are gitignored).

# ── Meta Ads (Performance + Campaigns tabs) ──────────────────────────────────
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=

# ── Instagram ────────────────────────────────────────────────────────────────
IG_USER_ID=

# ── Facebook ─────────────────────────────────────────────────────────────────
FB_PAGE_ID=
FB_PAGE_TOKEN=

# ── LinkedIn ─────────────────────────────────────────────────────────────────
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_ORG_ID=
LINKEDIN_API_VERSION=

# ── Jira (Design Board) ──────────────────────────────────────────────────────
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=

# ── Content calendar (Microsoft Graph or Google Sheets) ──────────────────────
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_SHARE_URL=
MS_SHEET_NAME=
GOOGLE_SHEETS_ID=
GOOGLE_SHEETS_API_KEY=
GOOGLE_SHEETS_CSV_URL=

# ── Campaigns tab — campaign brief index (campaign_id | brief_url) ───────────
# The dashboard joins this with Meta by Campaign ID to show the "Open Brief" button.
# Configure ONE of the three sources below. brief_url can be any link (Word doc on
# SharePoint/OneDrive, Google Doc, etc.) — it is only opened in a new tab, never read.

# Source A — published Google Sheet CSV (EASIEST: no app, no API key). In Google Sheets:
#   File → Share → Publish to web → choose the sheet → CSV → copy the URL.
BRIEFS_CSV_URL=

# Source B — Google Sheets API key (share the sheet "Anyone with the link → Viewer").
BRIEFS_SHEET_ID=
BRIEFS_API_KEY=
BRIEFS_SHEET_RANGE=A1:Z2000

# Source C — SharePoint / OneDrive Excel via Microsoft Graph (needs an Azure AD app
# with application permission Files.Read.All / Sites.Read.All, admin consented).
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
SHAREPOINT_SITE_ID=
EXCEL_FILE_ID=
EXCEL_SHEET_NAME=Sheet1

# ── Leads tab — individual lead records ──────────────────────────────────────
# EASIEST (no Meta permission): a published Google Sheet of your leads. Columns become the
# detail fields; recognized headers: Date of Lead Capture, Full name, Email, Contact, Campaign
# (plus any custom questions: Designation, Platform, School, City, Bootcamp timing…).
# In Google Sheets: File → Share → Publish to web → the sheet → CSV → copy the URL.
LEADS_CSV_URL=
# OR a Google Sheets API key instead of publishing:
LEADS_SHEET_ID=
LEADS_API_KEY=
LEADS_SHEET_RANGE=A1:Z5000
# (Alternatively, pull live from Meta Lead Ads — needs META_ACCESS_TOKEN with leads_retrieval +
#  pages_manage_ads, FB_PAGE_ID, and a Page-admin role. Falls back to this only if no sheet is set.)

# ── Login gate (optional) ────────────────────────────────────────────────────
DASHBOARD_USER=
DASHBOARD_PASSWORD=
